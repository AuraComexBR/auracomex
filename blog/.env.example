# Chave da Anthropic Console (console.anthropic.com)
ANTHROPIC_API_KEY=

# Header secreto que a Vercel envia nos crons (gera um valor aleatório e
# configura como env var na Vercel; a Vercel injeta o header Authorization
# automaticamente quando CRON_SECRET está setado no projeto)
CRON_SECRET=

# CTA do Aura Comex usado ao final de cada post. O leitor é o agente de carga —
# a linguagem é sempre "use o Aura pra entregar excelência ao seu cliente",
# nunca "resolva a dor de quem embarca a carga".
NEXT_PUBLIC_AURA_CTA_URL=https://auracomex.app
NEXT_PUBLIC_AURA_CTA_TEXT=Entregue um serviço de excelência aos seus clientes com o Aura Comex

# Login da área de gestão (/admin) — HTTP Basic Auth, o navegador pede
# usuário/senha nativamente. Sem essas duas vars, /admin fica desativado.
ADMIN_USER=
ADMIN_PASSWORD=

# Chave gratuita do Unsplash (unsplash.com/developers -> New Application)
# Sem essa var, os posts saem sem imagem de capa (não quebra a geração).
UNSPLASH_ACCESS_KEY=

# URL final e pública do blog (produção). Usada em SEO: sitemap, RSS,
# Open Graph, canonical. Em dev local pode deixar como está.
NEXT_PUBLIC_SITE_URL=https://auracomex.app/blog
